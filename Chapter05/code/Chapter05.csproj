    <Compile Remove="ch05_6_flight_models.cs" />
    <Compile Remove="ch05_7_passenger_input_validation.cs" />
    <Compile Remove="ch05_8_capability_validation_service.cs" />
    <Compile Remove="ch05_9_flight_tools_versioned.cs" />
    <Compile Remove="ch05_10_search_flights_streaming.cs" />
    <Compile Remove="ch05_11_book_flight_cancellation.cs" />
    <Compile Remove="ch05_12_book_flight_idempotency.cs" />
    <Compile Remove="ch05_13_mcp_tool_base_errors.cs" />
    <Compile Remove="ch05_14_opentelemetry_setup.cs" />
    <Compile Remove="ch05_15_search_flights_tracing.cs" />
    <Compile Remove="ch05_16_polly_resilience_pipelines.cs" />
    <Compile Remove="ch05_17_circuit_breaker_test.cs" />
    <None Include="ch05_1_program_minimal_setup.cs" />
