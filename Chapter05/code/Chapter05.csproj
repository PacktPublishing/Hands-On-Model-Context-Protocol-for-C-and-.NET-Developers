<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TravelBooking.Chapter05</RootNamespace>
    <AssemblyName>TravelBooking.Chapter05</AssemblyName>
    <!-- Disable Central Package Management for this standalone example -->
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- Exclude reference snippet files — they are incomplete examples for the book.
         Each ch05_*.cs file reproduces a single section of the chapter (partial classes,
         top-level builder fragments, overlapping record types). They are not intended
         to compile as a single unit; the full FlightsServer implementation is the
         subject of subsequent chapters. -->
    <Compile Remove="ch05_1_program_minimal_setup.cs" />
    <Compile Remove="ch05_2_di_env_idempotency_store.cs" />
    <Compile Remove="ch05_3_configuration_options_binding.cs" />
    <Compile Remove="ch05_4_airline_api_health_check.cs" />
