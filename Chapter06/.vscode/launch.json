{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Chapter 06 unit tests (skip Manual)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Chapter06.Tests.csproj",
        "--filter",
        "Execution!=Manual"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ]
}
